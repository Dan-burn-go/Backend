{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"service-.*\"}",
          "legendFormat": "{{job}} - Process CPU"
        },
        {
          "expr": "system_cpu_usage{job=~\"service-.*\"}",
          "legendFormat": "{{job}} - System CPU"
        }
      ]
    },
    {
      "title": "Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"service-.*\", area=\"heap\"}",
          "legendFormat": "{{job}} - {{id}} Used"
        },
        {
          "expr": "jvm_memory_max_bytes{job=~\"service-.*\", area=\"heap\"}",
          "legendFormat": "{{job}} - {{id}} Max"
        }
      ]
    },
    {
      "title": "Non-Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"service-.*\", area=\"nonheap\"}",
          "legendFormat": "{{job}} - {{id}}"
        }
      ]
    },
    {
      "title": "GC Pause Count (per min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10, "drawStyle": "bars" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=~\"service-.*\"}[1m])",
          "legendFormat": "{{job}} - {{cause}}"
        }
      ]
    },
    {
      "title": "GC Pause Duration (per min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"service-.*\"}[1m])",
          "legendFormat": "{{job}} - {{cause}}"
        }
      ]
    },
    {
      "title": "Live Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"service-.*\"}",
          "legendFormat": "{{job}} - Live"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=~\"service-.*\"}",
          "legendFormat": "{{job}} - Daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{job=~\"service-.*\"}",
          "legendFormat": "{{job}} - Peak"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(jvm_memory_used_bytes, job)",
        "regex": "service-.*",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "JVM Dashboard",
  "uid": "danburn-jvm",
  "version": 1
}
