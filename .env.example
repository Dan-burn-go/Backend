# Database Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=danburn
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Spring DataSource Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/danburn?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
SPRING_DATA_REDIS_HOST=localhost

# Observability Configuration
OTLP_URL=http://localhost:4318/v1/metrics
LOKI_URL=http://localhost:3100/loki/api/v1/push

# Service URLs
CORE_SERVICE_URL=http://localhost:8081

# Application Ports
GATEWAY_PORT=8080
CORE_SERVICE_PORT=8081

# Grafana Configuration
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# Application Environment
SPRING_PROFILES_ACTIVE=local

# Seoul Open API
SEOUL_API_KEY=your_api_key_here

# Congestion Scheduler Configuration
CONGESTION_SCHEDULER_INTERVAL=300000
CONGESTION_SCHEDULER_INITIAL_DELAY=10000
CONGESTION_CLEANUP_CRON=0 0 3 * * *
CONGESTION_CLEANUP_RETENTION_DAYS=7

# Service URLs
CONGESTION_SERVICE_URL=http://localhost:8082
MAP_SERVICE_URL=http://localhost:8083
TRANSPORT_SERVICE_URL=http://localhost:8084
AI_SERVICE_URL=http://localhost:8085